{
  "r-ship": {
    "name": "/r:ship",
    "type": "skill-with-subagents",
    "description": "Composite release workflow — preflight, verification, release prep, publish, report",
    "dispatches": ["qa", "reviewer"],
    "dispatch_mode": "parallel",
    "reads_governance": ["index.md", "verification.md", "conventions.md"]
  },
  "r-audit": {
    "name": "/r:audit",
    "type": "skill-with-subagents",
    "description": "Full codebase audit — dispatches parallel reviewer and qa subagents",
    "dispatches": ["reviewer", "reviewer", "reviewer", "qa"],
    "dispatch_mode": "parallel",
    "reads_governance": ["index.md", "verification.md", "anti-patterns.md", "constraints.md", "architecture.md"]
  },
  "r-refresh": {
    "name": "/r:refresh",
    "type": "skill",
    "description": "Re-scan codebase and update governance files",
    "dispatches": [],
    "dispatch_mode": "none",
    "reads_governance": ["index.md", "architecture.md", "conventions.md", "verification.md", "constraints.md", "anti-patterns.md"]
  },
  "r-sync": {
    "name": "/r:sync",
    "type": "skill",
    "description": "Pull emergency edits from ~/.claude/ back to rdf/canonical/",
    "dispatches": [],
    "dispatch_mode": "none",
    "reads_governance": []
  },
  "utility-commands": {
    "r-util-mem-compact": {
      "slash-command": "/r:util:mem-compact",
      "description": "Archive stale MEMORY.md entries",
      "source": "canonical/commands/r-util-mem-compact.md",
      "execution": "skill"
    },
    "r-util-doc-gen": {
      "slash-command": "/r:util:doc-gen",
      "description": "Generate docs for a specific surface",
      "source": "canonical/commands/r-util-doc-gen.md",
      "execution": "skill"
    },
    "r-util-ci-gen": {
      "slash-command": "/r:util:ci-gen",
      "description": "Generate CI workflow from test infra",
      "source": "canonical/commands/r-util-ci-gen.md",
      "execution": "skill"
    },
    "r-util-lib-sync": {
      "slash-command": "/r:util:lib-sync",
      "description": "Cross-project library drift detection",
      "source": "canonical/commands/r-util-lib-sync.md",
      "execution": "skill"
    },
    "r-util-lib-release": {
      "slash-command": "/r:util:lib-release",
      "description": "Shared library release lifecycle",
      "source": "canonical/commands/r-util-lib-release.md",
      "execution": "skill"
    },
    "r-util-code-scan": {
      "slash-command": "/r:util:code-scan",
      "description": "Structured pattern-class bug finder",
      "source": "canonical/commands/r-util-code-scan.md",
      "execution": "skill"
    },
    "r-util-code-modernize": {
      "slash-command": "/r:util:code-modernize",
      "description": "Assess codebase maturity + plan",
      "source": "canonical/commands/r-util-code-modernize.md",
      "execution": "skill"
    },
    "r-util-test-dedup": {
      "slash-command": "/r:util:test-dedup",
      "description": "Find duplicate/overlapping tests",
      "source": "canonical/commands/r-util-test-dedup.md",
      "execution": "skill"
    },
    "r-util-chg-gen": {
      "slash-command": "/r:util:chg-gen",
      "description": "Generate changelog entries from diff",
      "source": "canonical/commands/r-util-chg-gen.md",
      "execution": "skill"
    },
    "r-util-chg-dedup": {
      "slash-command": "/r:util:chg-dedup",
