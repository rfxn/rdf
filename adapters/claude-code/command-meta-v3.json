{
  "r-spec": {
    "name": "/r:spec",
    "type": "skill",
    "description": "Design workflow — discover, brainstorm, write spec, challenge review",
    "dispatches": [],
    "dispatch_mode": "none",
    "reads_governance": ["index.md", "architecture.md", "conventions.md"]
  },
  "r-plan": {
    "name": "/r:plan",
    "type": "skill-with-subagents",
    "description": "Planning workflow — decompose spec into PLAN.md, challenge review",
    "dispatches": ["reviewer"],
    "dispatch_mode": "sequential",
    "reads_governance": ["index.md", "architecture.md", "conventions.md", "verification.md"]
  },
  "r-build": {
    "name": "/r:build",
    "type": "subagent-foreground",
    "description": "Execute implementation plan phase via dispatcher subagent",
    "dispatches": ["dispatcher"],
    "dispatch_mode": "sequential",
    "reads_governance": ["index.md", "conventions.md", "constraints.md", "verification.md", "anti-patterns.md"]
  },
  "r-ship": {
    "name": "/r:ship",
    "type": "skill-with-subagents",
    "description": "Composite release workflow — preflight, verification, release prep, publish, report",
    "dispatches": ["qa", "reviewer"],
    "dispatch_mode": "parallel",
    "reads_governance": ["index.md", "verification.md", "conventions.md"]
  },
  "r-audit": {
    "name": "/r:audit",
    "type": "skill-with-subagents",
    "description": "Full codebase audit — dispatches parallel reviewer and qa subagents",
    "dispatches": ["reviewer", "reviewer", "reviewer", "qa"],
    "dispatch_mode": "parallel",
    "reads_governance": ["index.md", "verification.md", "anti-patterns.md", "constraints.md", "architecture.md"]
  },
