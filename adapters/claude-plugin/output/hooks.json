{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/adapters/claude-plugin/output/scripts/post-edit-lint.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "prompt": "Context compaction imminent. Save work-in-progress state: write a status checkpoint to work-output/ if mid-phase, verify MEMORY.md reflects current state.",
            "type": "prompt"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/adapters/claude-plugin/output/scripts/precompact-snapshot.sh",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/adapters/claude-plugin/output/scripts/pre-commit-validate.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/adapters/claude-plugin/output/scripts/session-end-capture.sh",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/adapters/claude-plugin/output/scripts/session-start-context.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "compact"
      },
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/adapters/claude-plugin/output/scripts/session-start-inject.sh",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/adapters/claude-plugin/output/scripts/subagent-stop.sh",
            "type": "command"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "command": "\"${CLAUDE_PLUGIN_ROOT}\"/adapters/claude-plugin/output/scripts/context-bar.sh",
    "type": "command"
  }
}
